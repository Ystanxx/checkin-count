{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "团队打卡数据处理",
  "version": "0.1.0",
  "identifier": "com.stan.attendance",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "团队打卡数据处理",
        "width": 1440,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "allowDowngrades": false,
      "tsp": false
    },
    "shortDescription": "本地离线的团队打卡数据处理工具",
    "category": "Productivity"
  }
}
